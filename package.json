{
  "name": "cerbero",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter @cerbero/api typecheck && bun run --filter @cerbero/dashboard typecheck",
    "dev:api": "bun --env-file=.env run --filter @cerbero/api dev",
    "dev:dashboard": "bun --env-file=.env run --filter @cerbero/dashboard dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "lefthook": "^1.7.0",
    "typescript": "^5.6.0"
  }
}
