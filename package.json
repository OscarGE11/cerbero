{
  "name": "cerbero",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter @cerbero/api typecheck && bun run --filter @cerbero/dashboard typecheck",
    "build": "bun run --filter @cerbero/dashboard build",
    "env:check": "bun scripts/check-env.ts",
    "env:print": "bun scripts/check-env.ts -- --print",
    "dev": "bash scripts/dev.sh",
    "dev:api": "bun --env-file=.env run --filter @cerbero/api dev",
    "dev:dashboard": "bun --env-file=.env run --filter @cerbero/dashboard dev",
    "auth:token": "bun --env-file=.env scripts/get-jwt.ts",
    "auth:link-code": "bun --env-file=.env scripts/create-link-code.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "lefthook": "^1.7.0",
    "typescript": "^5.6.0",
    "zod": "^3.24.0"
  }
}
