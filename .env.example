# Cerbero — variables de entorno (desarrollo)
# Copia este archivo a .env y rellena los valores.
# Comprobar: bun run env:check

# ── Compartidas (API + dashboard) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── API (apps/api) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
PORT=3001
DASHBOARD_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Correo (recuperación de contraseña) — opcional en desarrollo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Cerbero <noreply@cerbero.app>

# En producción (Railway) también necesitas:
# NODE_ENV=production
# TELEGRAM_WEBHOOK_SECRET=<openssl rand -hex 32>

# ── Dashboard (apps/dashboard) ───────────────────────────────────────
# Si no defines NEXT_PUBLIC_*, next.config.mjs usa SUPABASE_* del .env raíz
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TELEGRAM_WEBAPP_URL=http://localhost:3000/telegram

# ── Solo scripts locales (auth:token, auth:link-code) ────────────────
DEV_USER_EMAIL=
DEV_USER_PASSWORD=

# Plantilla producción: .env.production.example
# Guía completa: docs/deployment.md
