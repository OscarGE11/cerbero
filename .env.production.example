# Cerbero — plantilla de producción (NO commitear con valores reales)
# Configura estas variables en Railway (API) y Vercel (dashboard).

# ── Railway (API + bot) ──────────────────────────────────────────────
NODE_ENV=production

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=6c9f4dc8166a795b829ae9d2037259544fb88ec60ea0b00880aceb3f9031f11e   # openssl rand -hex 32

# Obligatorio en Railway si el dominio activo no es RAILWAY_PUBLIC_DOMAIN:
PUBLIC_API_URL=https://cerbero-api.up.railway.app

# URL pública del dashboard en Vercel
DASHBOARD_URL=https://cerbero.vercel.app

# Debe coincidir con DASHBOARD_URL
CORS_ORIGIN=https://cerbero.vercel.app

# Railway inyecta PORT automáticamente

# Correo (recuperación de contraseña)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=Cerbero <noreply@tudominio.com>

# ── Vercel (dashboard) ───────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_API_URL=https://cerbero-api.up.railway.app
# NEXT_PUBLIC_TELEGRAM_WEBAPP_URL=https://cerbero.vercel.app/telegram
